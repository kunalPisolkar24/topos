# =============================================================================
# Topos — Production Environment Example
# =============================================================================
# Copy this file to `.env` at the repo root and fill in real values.
#   cp infrastructure/docker/prod/.env.example .env
#
# This file is consumed by `make` / `docker compose` via
# `--env-file .env`. Vars without defaults below MUST be set; vars with
# defaults may be omitted. Service-specific sections are grouped by the
# service that reads them.
#
# Note: only the search-service block is shown in detail; other services
# (user, content, ai, gateway, frontend) need their own analogous blocks.
# =============================================================================

# --- Network ----------------------------------------------------------------
APP_NETWORK=blog_app_network

# --- Kafka (shared by all services) ----------------------------------------
KAFKA_BROKERS=kafka-1:9092,kafka-2:9092,kafka-3:9092
KAFKA_TOPIC=posts
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_1_CONTAINER=prod-kafka-1
KAFKA_INT_PORT_1=9092
KAFKA_EXT_PORT_1=9092
KAFKA_2_CONTAINER=prod-kafka-2
KAFKA_INT_PORT_2=9092
KAFKA_EXT_PORT_2=9092
KAFKA_3_CONTAINER=prod-kafka-3
KAFKA_INT_PORT_3=9092
KAFKA_EXT_PORT_3=9092
KAFKA_UI_CONTAINER=prod-kafka-ui
KAFKA_UI_INT_PORT=8080
KAFKA_UI_EXT_PORT=8080
INIT_KAFKA_CONTAINER=prod-init-kafka

# --- Search Service — containers and ports --------------------------------
SEARCH_API_CONTAINER=prod-search-api
SEARCH_API_INT_PORT=4003
SEARCH_API_EXT_PORT=4003
SEARCH_WORKER_CONTAINER=prod-search-worker
SEARCH_WORKER_INT_PORT=7091
SEARCH_WORKER_EXT_PORT=7091
SEARCH_NODE_ENV=production

# --- Search Service — Elasticsearch ---------------------------------------
SEARCH_ES_URL=http://search-es01:9200
SEARCH_ES_INT_PORT=9200
SEARCH_ES_EXT_PORT=9200
SEARCH_ES_01_CONTAINER=prod-search-es01
SEARCH_ES_02_CONTAINER=prod-search-es02
SEARCH_ES_03_CONTAINER=prod-search-es03
SEARCH_KIBANA_CONTAINER=prod-search-kibana
SEARCH_KIBANA_INT_PORT=5601
SEARCH_KIBANA_EXT_PORT=5601
SEARCH_ELASTICSEARCH_INDEX=posts
SEARCH_ES_TLS_REJECT_UNAUTHORIZED=true
SEARCH_ES_REFRESH_POLICY=wait_for
SEARCH_ES_REQUEST_TIMEOUT_MS=30000
SEARCH_ES_MAX_RETRIES=3
SEARCH_BULK_CHUNK_SIZE=1000

# --- Search Service — Redis Sentinel cluster ------------------------------
# Either SEARCH_REDIS_URL (single instance) or SEARCH_REDIS_SENTINEL_HOSTS
# (HA cluster) must be provided. The schema rejects booting with neither.
SEARCH_REDIS_URL=
SEARCH_REDIS_SENTINEL_HOSTS=search-redis-sentinel-1:26379,search-redis-sentinel-2:26379,search-redis-sentinel-3:26379
SEARCH_REDIS_MASTER_NAME=mymaster
SEARCH_REDIS_MASTER_CONTAINER=prod-search-redis-master
SEARCH_REDIS_REPLICA_1_CONTAINER=prod-search-redis-replica-1
SEARCH_REDIS_REPLICA_2_CONTAINER=prod-search-redis-replica-2
SEARCH_REDIS_SENTINEL_1_CONTAINER=prod-search-redis-sentinel-1
SEARCH_REDIS_SENTINEL_2_CONTAINER=prod-search-redis-sentinel-2
SEARCH_REDIS_SENTINEL_3_CONTAINER=prod-search-redis-sentinel-3
SEARCH_REDIS_PASSWORD=
SEARCH_REDIS_SENTINEL_PASSWORD=
SEARCH_REDIS_SENTINEL_TLS=false

# --- Search Service — cache -----------------------------------------------
SEARCH_CACHE_DEFAULT_TTL_SECONDS=120
SEARCH_MAX_QUERY_LENGTH=512

# --- Search Service — Kafka consumer --------------------------------------
SEARCH_KAFKA_CLIENT_ID=search-service
SEARCH_KAFKA_GROUP_ID=search-workers-group
SEARCH_TOPIC_POSTS=posts
SEARCH_TOPIC_DLQ=posts.dlq
SEARCH_KAFKA_FROM_BEGINNING=false
SEARCH_KAFKA_PARTITIONS_CONCURRENT=3
SEARCH_KAFKA_SESSION_TIMEOUT_MS=30000
SEARCH_KAFKA_HEARTBEAT_INTERVAL_MS=3000

# --- Search Service — HTTP / Security -------------------------------------
SEARCH_CORS_ORIGINS=https://app.example.com
SEARCH_AUTH_ENABLED=false
SEARCH_AUTH_JWKS_URI=
SEARCH_AUTH_AUDIENCE=
SEARCH_AUTH_ISSUER=
SEARCH_AUTH_ALGORITHMS=RS256
SEARCH_AUTH_CACHE_MAX_AGE_MS=600000
SEARCH_AUTH_CLOCK_TOLERANCE_SEC=5
SEARCH_METRICS_BASIC_AUTH=
SEARCH_HTTP_BODY_LIMIT_KB=256
SEARCH_HTTP_TRUST_PROXY=false

# --- Search Service — Operations ------------------------------------------
SEARCH_SHUTDOWN_TIMEOUT_MS=15000
SEARCH_LOG_LEVEL=
SEARCH_SERVICE_NAME=search-service
SEARCH_SERVICE_VERSION=0.0.0
