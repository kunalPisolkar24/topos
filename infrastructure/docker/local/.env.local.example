# =============================================================================
# Topos — Local Development Environment
# =============================================================================
# Copy this file to .env.local and fill in any required values.
#   cp .env.local.example .env.local
# =============================================================================

# --- Network ----------------------------------------------------------------
APP_NETWORK=topos_local_network

# --- Kafka ------------------------------------------------------------------
KAFKA_INT_PORT=9092
KAFKA_EXT_PORT=9092
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_TOPIC=posts
KAFKA_BROKERS=kafka-1:9092
KAFKA_UI_EXT_PORT=8080
KAFKA_UI_INT_PORT=8080

# --- Content Service --------------------------------------------------------
CONTENT_SERVICE_CONTAINER=local-content-service
CONTENT_SERVICE_INT_PORT=4002
CONTENT_SERVICE_EXT_PORT=4002
CONTENT_WORKER_CONTAINER=local-content-worker
CONTENT_WORKER_INT_PORT=4012
CONTENT_WORKER_EXT_PORT=4012
CONTENT_MONGO_URI=mongodb://local-content-mongo:27017
CONTENT_MONGO_INT_PORT=27017
CONTENT_MONGO_EXT_PORT=27017
CONTENT_DB_NAME=blog_content
CONTENT_JWT_SECRET=local-dev-secret
CONTENT_REDIS_URL=redis://local-content-redis:6379
CONTENT_REDIS_EXT_PORT=6379
CONTENT_AI_REQUIRED=false

# --- User Service -----------------------------------------------------------
USER_SERVICE_CONTAINER=local-user-service
USER_SERVICE_INT_PORT=4001
USER_SERVICE_EXT_PORT=4001
USER_JWT_SECRET=local-dev-secret
USER_POSTGRES_USER=topos_user
USER_POSTGRES_PASSWORD=topos_pass
USER_POSTGRES_DB=topos_users
USER_POSTGRES_INT_PORT=5432
USER_POSTGRES_EXT_PORT=5432
USER_DATABASE_URL=postgresql://topos_user:topos_pass@local-user-postgres:5432/topos_users
USER_REDIS_URL=redis://local-user-redis:6379
USER_REDIS_EXT_PORT=6380
USER_CACHE_TTL_MS=3600000
USER_MISSING_CACHE_TTL_MS=60000

# --- Search Service ---------------------------------------------------------
SEARCH_API_CONTAINER=local-search-api
SEARCH_API_INT_PORT=4003
SEARCH_API_EXT_PORT=4003
SEARCH_WORKER_CONTAINER=local-search-worker
SEARCH_WORKER_INT_PORT=7091
SEARCH_WORKER_EXT_PORT=7091
SEARCH_KAFKA_GROUP_ID=search-workers-group
SEARCH_KAFKA_CLIENT_ID=search-service
SEARCH_ES_URL=http://local-search-es:9200
SEARCH_ES_INT_PORT=9200
SEARCH_ES_EXT_PORT=9200
SEARCH_REDIS_URL=redis://local-search-redis:6379
SEARCH_REDIS_EXT_PORT=6381

# --- AI Service -------------------------------------------------------------
AI_SERVICE_CONTAINER=local-ai-service
AI_SERVICE_INT_PORT=50051
AI_SERVICE_EXT_PORT=50051
AI_METRICS_INT_PORT=19090
AI_LOG_LEVEL=DEBUG
AI_TIMEOUT_SECONDS=30
# REQUIRED: Set your Lightning AI API key
LIGHTNING_AI_API_KEY=
AI_LIGHTNING_MODEL=

# --- Gateway ----------------------------------------------------------------
GATEWAY_CONTAINER=local-gateway
GATEWAY_INT_PORT=4000
GATEWAY_EXT_PORT=4000

# --- Frontend ---------------------------------------------------------------
FRONTEND_CONTAINER=local-frontend
FRONTEND_INT_PORT=3000
FRONTEND_EXT_PORT=3000
VITE_GRAPHQL_URL=http://localhost:4000/graphql
VITE_BACKEND_URL=http://localhost:4000
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=

# --- AI Service URL (used by content service) --------------------------------
AI_SERVICE_URL=ai-service:50051
