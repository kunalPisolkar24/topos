generator client {
    provider = "prisma-client"
    output   = "../src/generated/prisma"
}

datasource db {
    provider = "postgresql"
}

model User {
    id        Int      @id @default(autoincrement())
    username  String   @unique
    email     String   @unique
    password  String
    name      String?
    bio       String?
    avatarUrl String?
    bannerUrl String?
    createdAt DateTime @default(now())
}
