KAFKA_BROKER=kafka:29092
ELASTICSEARCH_URL=http://elasticsearch:9200
PORT=8002

# Service identity
SERVICE_NAME=search-service
SERVICE_VERSION=0.0.0

# Elasticsearch
ELASTICSEARCH_INDEX=posts
ES_TLS_REJECT_UNAUTHORIZED=true
ES_REFRESH_POLICY=wait_for
ES_REQUEST_TIMEOUT_MS=30000
ES_MAX_RETRIES=3
BULK_CHUNK_SIZE=1000

# Redis (one of the two must be set)
REDIS_URL=
REDIS_SENTINEL_HOSTS=
REDIS_MASTER_NAME=mymaster
REDIS_PASSWORD=
REDIS_SENTINEL_PASSWORD=
REDIS_SENTINEL_TLS=false

# Cache
CACHE_DEFAULT_TTL_SECONDS=120
MAX_QUERY_LENGTH=512

# Kafka
KAFKA_CLIENT_ID=search-service
KAFKA_GROUP_ID=search-workers-group
TOPIC_POSTS=posts
TOPIC_DLQ=posts.dlq
KAFKA_FROM_BEGINNING=false
KAFKA_PARTITIONS_CONCURRENT=3
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_HEARTBEAT_INTERVAL_MS=3000

# API
API_PORT=4003
WORKER_METRICS_PORT=7091

# HTTP / Security
CORS_ORIGINS=
AUTH_ENABLED=false
METRICS_BASIC_AUTH=
HTTP_BODY_LIMIT_KB=256

# Operations
SHUTDOWN_TIMEOUT_MS=15000
LOG_LEVEL=
