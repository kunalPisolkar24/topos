{
  "name": "elasticsearch-worker",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "start:api": "node dist/app-api.js",
    "start:worker": "node dist/app-worker.js",
    "dev:api": "nodemon --watch 'src/**/*.ts' --exec 'node --loader ts-node/esm' src/app-api.ts",
    "dev:worker": "nodemon --watch 'src/**/*.ts' --exec 'node --loader ts-node/esm' src/app-worker.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.config.int.ts",
    "test:integration:watch": "vitest --config vitest.config.int.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "engines": {
    "node": ">=20.18.1"
  },
  "dependencies": {
    "@apollo/server": "^5.2.0",
    "@apollo/subgraph": "^2.12.2",
    "@as-integrations/express5": "^1.1.2",
    "@elastic/elasticsearch": "^8.15.0",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "graphql": "^16.12.0",
    "graphql-depth-limit": "^1.1.0",
    "graphql-tag": "^2.12.6",
    "helmet": "^8.2.0",
    "ioredis": "^5.8.2",
    "jose": "^6.2.3",
    "kafkajs": "^2.2.4",
    "pino": "^10.1.0",
    "prom-client": "^15.1.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/graphql-depth-limit": "^1.1.6",
    "@types/node": "^24.10.0",
    "@vitest/coverage-v8": "^4.0.17",
    "nodemon": "^3.1.10",
    "testcontainers": "^12.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17",
    "vitest-mock-extended": "^3.1.0"
  },
  "type": "module"
}
